{
  "name": "Luminate Online Page Editor",
  "version": "1.13",
  "manifest_version": 3,
  "description": "Edit Luminate Online pages with just one click.",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "action": {
    "default_icon": "logo128.png",
    "default_title": "Edit this page"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": [
    "tabs",
    "storage"
  ]
}

{
  "name": "luminate-edit",
  "version": "2.0.0-alpha.1",
  "description": "Browser extension providing one-click access to Luminate Online administrative interfaces",
  "main": "shared/src/luminateEdit.js",
  "type": "module",
  "scripts": {
    "dev": "npm run watch",
    "watch": "concurrently \"npm run watch:chrome\" \"npm run watch:firefox\"",
    "watch:chrome": "webpack --watch --config webpack.chrome.config.js",
    "watch:firefox": "webpack --watch --config webpack.firefox.config.js",
    "build": "npm run build:all",
    "build:all": "npm run clean && concurrently \"npm run build:chrome\" \"npm run build:firefox\" \"npm run build:opera\"",
    "build:chrome": "webpack --config webpack.chrome.config.js --mode production",
    "build:firefox": "webpack --config webpack.firefox.config.js --mode production",
    "build:opera": "webpack --config webpack.opera.config.js --mode production",
    "build:safari": "echo 'Safari build process TBD - requires conversion to WebExtension format'",
    "clean": "rimraf dist",
    "lint": "npm run lint:js && npm run lint:manifest",
    "lint:js": "eslint \"**/*.js\" --ignore-pattern dist/ --ignore-pattern node_modules/",
    "lint:manifest": "web-ext lint --source-dir=chrome",
    "lint:fix": "eslint \"**/*.js\" --fix --ignore-pattern dist/ --ignore-pattern node_modules/",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "package": "npm run package:all",
    "package:all": "npm run build && npm run package:chrome && npm run package:firefox && npm run package:opera",
    "package:chrome": "cd dist/chrome && zip -r ../../luminate-edit-chrome.zip .",
    "package:firefox": "web-ext build --source-dir=dist/firefox --artifacts-dir=.",
    "package:opera": "cd dist/opera && zip -r ../../luminate-edit-opera.zip .",
    "validate": "npm run lint && npm run format:check && npm run test",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "release": "npm run validate && npm run build && npm run package",
    "docs": "jsdoc -c jsdoc.config.json",
    "serve:firefox": "web-ext run --source-dir=dist/firefox",
    "serve:chrome": "echo 'Load dist/chrome manually in chrome://extensions'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeeboo-digital/luminateEdit.git"
  },
  "keywords": [
    "luminate-online",
    "blackbaud",
    "convio",
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "productivity",
    "nonprofit",
    "fundraising"
  ],
  "author": {
    "name": "Noah Cooper",
    "url": "https://github.com/noahcooper"
  },
  "contributors": [
    {
      "name": "Yeeboo Digital",
      "url": "https://github.com/yeeboo-digital"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yeeboo-digital/luminateEdit/issues"
  },
  "homepage": "https://github.com/yeeboo-digital/luminateEdit#readme",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@types/chrome": "^0.0.262",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/jest": "^29.5.12",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.9.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdoc": "^4.0.2",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "web-ext": "^7.11.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "shared/src/**/*.js",
      "chrome/src/**/*.js",
      "firefox/src/**/*.js",
      "opera/src/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.js$": "babel-loader"
    }
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Opera versions"
  ]
}
